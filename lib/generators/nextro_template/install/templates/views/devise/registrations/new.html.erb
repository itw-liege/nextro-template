<h4 class="mb-3 f-w-400 text-center"><%= t('devise.general.signup_title', default: t('devise.registrations.new.sign_up')) %></h4>

<%= bootstrap_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= f.email_field :email, autofocus: true, label_as_placeholder: true %>
  <%= f.password_field :password, autocomplete: "off", label_as_placeholder: true %>
  <%= f.password_field :password_confirmation, autocomplete: "off", label_as_placeholder: true %>
  <%= f.check_box :remember_me %>
  <%= f.submit t('devise.registrations.new.sign_up', default: 'Sign up'), class: 'btn btn-block btn-primary mb-4 mt-4' %>
<% end %>

<%= render "devise/shared/links" %>
