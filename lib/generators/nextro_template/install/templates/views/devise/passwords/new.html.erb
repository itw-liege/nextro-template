<h4 class="mb-3 f-w-400 text-center"><%= t('devise.general.forgot_password', default: t('devise.passwords.new.forgot_your_password')) %></h4>

<p><%= t('devise.general.forgot_password_p1', default: t('devise.passwords.send_instructions')) %></p>

<%= bootstrap_form_for(resource, as: resource_name, url: password_path(resource_name)) do |f| %>
  <%= f.email_field :email, autofocus: true, label_as_placeholder: true %>
  <%= f.submit t('devise.passwords.new.send_me_reset_password_instructions', default: 'Send me reset password instructions'), class: 'btn btn-block btn-primary mb-4 mt-4' %>
<% end %>

<%= render "devise/shared/links" %>
