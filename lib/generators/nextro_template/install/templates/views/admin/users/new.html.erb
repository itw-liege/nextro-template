<%= b_card(t('admin.users.title.new', default: 'Nouvel utilisateur')) do %>
  <%= bootstrap_form_with model: [:admin, @user], url: admin_users_path do |f| %>
    <%= f.email_field :email if @user.respond_to?(:email) %>
    <%= f.text_field :firstname if @user.respond_to?(:firstname) %>
    <%= f.text_field :lastname if @user.respond_to?(:lastname) %>
    <%= f.password_field :password if @user.respond_to?(:password) %>
    <%= f.password_field :password_confirmation if @user.respond_to?(:password_confirmation) %>
    <%= f.submit t('nextro.forms.save', default: 'Sauvegarder'), class: 'btn btn-success' %>
  <% end %>
<% end %>
