<%= content_for :buttons do %>
  <% if defined?(User) %>
    <%= link_to t('nextro.forms.list.add', default: 'Ajouter'), new_admin_user_path, class: 'btn btn-primary' %>
  <% end %>
<% end %>

<%= b_card(t('admin.users.sidebar_left_title', default: 'Utilisateurs')) do %>
  <% if @users.any? %>
    <div class="dt-responsive table-responsive">
      <table class="table table-striped table-bordered nowrap nextro-datatable" data-page-length="10" data-order='[[ 0, "asc" ]]'>
        <thead>
          <tr>
            <th><%= t('activerecord.attributes.user.firstname', default: 'Prénom') %></th>
            <th><%= t('activerecord.attributes.user.lastname', default: 'Nom') %></th>
            <th><%= t('activerecord.attributes.user.email', default: 'Email') %></th>
            <th><%= t('activerecord.attributes.user.created_at', default: 'Créé le') %></th>
            <th data-orderable="false" class="actions text-right"><%= t('nextro.table.actions', default: 'Actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= user.respond_to?(:firstname) ? user.firstname : '-' %></td>
              <td><%= user.respond_to?(:lastname) ? user.lastname : '-' %></td>
              <td><%= user.respond_to?(:email) ? user.email : user.to_s %></td>
              <td><%= user.respond_to?(:created_at) ? l(user.created_at, format: :short) : '-' %></td>
              <td class="text-right">
                <%= table_edit_button(edit_admin_user_path(user)) if defined?(User) %>
                <%= table_delete_button(admin_user_path(user)) if defined?(User) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">
      Configurez Devise et le modèle User pour gérer les utilisateurs :
    </p>
    <pre class="bg-light p-3"><code>rails g devise:install
rails g devise User
rails db:migrate</code></pre>
  <% end %>
<% end %>
